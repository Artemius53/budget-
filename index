/* ---- Калькулятор (не хранится в базе, только в памяти сессии) ---- */
function calcRoundClean(n){
  return parseFloat(n.toFixed(8));
}
function calcCompute(a, b, op){
  switch(op){
    case '+': return a+b;
    case '−': return a-b;
    case '×': return a*b;
    case '÷': return b===0 ? 0 : a/b;
    default: return b;
  }
}
function calcInputDigit(d){
  if(calcWaitingForOperand){ calcDisplay = d; calcWaitingForOperand = false; }
  else { calcDisplay = (calcDisplay==='0') ? d : calcDisplay + d; }
  render();
}
function calcInputDot(){
  if(calcWaitingForOperand){ calcDisplay = '0.'; calcWaitingForOperand = false; }
  else if(!calcDisplay.includes('.')){ calcDisplay += '.'; }
  render();
}
function calcClear(){
  calcDisplay = '0'; calcPrevValue = null; calcOperator = null; calcWaitingForOperand = false;
  render();
}
function calcBackspace(){
  calcDisplay = calcDisplay.length>1 ? calcDisplay.slice(0,-1) : '0';
  render();
}
function calcSetOperator(op){
  const inputValue = parseFloat(calcDisplay);
  if(calcPrevValue===null){ calcPrevValue = inputValue; }
  else if(calcOperator && !calcWaitingForOperand){
    calcPrevValue = calcRoundClean(calcCompute(calcPrevValue, inputValue, calcOperator));
    calcDisplay = String(calcPrevValue);
  }
  calcOperator = op;
  calcWaitingForOperand = true;
  render();
}
function calcEquals(){
  const inputValue = parseFloat(calcDisplay);
  if(calcOperator!==null && calcPrevValue!==null){
    calcDisplay = String(calcRoundClean(calcCompute(calcPrevValue, inputValue, calcOperator)));
    calcPrevValue = null;
    calcOperator = null;
    calcWaitingForOperand = true;
  }
  render();
}

