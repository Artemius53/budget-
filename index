        <button type="submit" class="submit">Добавить доход</button>
      </form>
      <div class="list">${rowsHtml}</div>
    `;
  } else if(financeSub==='credits'){
    body = `
      <form class="add" id="creditForm">
        <div class="full"><label>Новое кредитное обязательство</label></div>
        <div><label>Владелец</label><select id="crPerson">${PEOPLE.map(p=>`<option>${p}</option>`).join('')}</select></div>
        <div><label>Тип</label><select id="crType"><option>Кредит</option><option>Ипотека</option><option>Кредитная карта</option></select></div>
        <div class="full"><label>Название</label><input type="text" id="crName" placeholder="напр., Кредитка Тбанк"></div>
        <div><label>Сумма долга, ₽</label><input type="number" id="crTotal" step="0.01" min="0"></div>
        <div><label>Ставка, %</label><input type="number" id="crRate" step="0.01" min="0"></div>
        <div><label>Платёж/мес, ₽</label><input type="number" id="crPayment" step="0.01" min="0"></div>
        <div><label>День платежа</label><input type="number" id="crDay" min="1" max="31" value="1"></div>
        <button type="submit" class="submit">Добавить кредит</button>
      </form>
      ${credits.length===0? '<div class="empty">Кредитных обязательств нет.</div>' : credits.map(c=>{
        const remaining = creditRemaining(c);
        const paidThisMonth = creditPaidThisMonth(c);
        return `
          <div class="row-entry">
            <div class="row">
              <span class="desc">
                <span class="cat">${c.name}</span>
                <span class="place">${c.creditType||'Кредит'} · ${c.person} · ставка ${c.rate!=null?c.rate:'—'}% · платёж ${c.paymentDay}&nbsp;числа</span>
              </span>
              <span class="leader"></span>
              <span class="amount">${fmt(remaining)} ₽</span>
              <button class="del" data-del-credit="${c.id}" aria-label="Удалить">×</button>
            </div>
            <div class="row-meta">
              ${paidThisMonth? '<span class="tag" style="color:var(--forest)">Оплачено в этом месяце</span>' : `<button class="buy-btn" data-pay-credit="${c.id}">Списать платёж ${fmt(c.monthlyPayment)} ₽</button>`}
            </div>
          </div>`;
      }).join('')}
      ${credits.length? `<div class="totals"><div class="row2 total"><span>Общий остаток долга</span><span class="neg">${fmt(credits.reduce((s,c)=>s+creditRemaining(c),0))} ₽</span></div></div>` : ''}
    `;
  } else {
    const totalGoalTarget = goals.reduce((s,g)=>s+(g.target||0),0);
    const totalGoalSaved = goals.reduce((s,g)=>s+(g.saved||0),0);
    const goalsListHtml = goals.length===0
      ? '<div class="empty">Пока нет целей.</div>'
      : goals.map(g=>{
          const pct = g.target>0 ? Math.min(100,(g.saved/g.target*100)) : 0;
          const done = g.saved>=g.target && g.target>0;
          const left = Math.max(0, g.target - g.saved);
          return `
            <div class="wish">
              <div class="wish-head">
                <span class="wish-name">${g.name}</span>
                <span class="wish-price">${fmt(g.target)} ₽</span>
                <button class="shop-edit no-toggle" data-edit-goal="${g.id}" aria-label="Редактировать">✎</button>
                <button class="wish-del" data-del-goal="${g.id}" aria-label="Удалить">×</button>
              </div>
              <div class="wish-progress-track"><span class="wish-progress-fill ${done?'done':''}" style="width:${pct}%"></span></div>
              <div class="wish-info">
                <span class="wish-saved">Накоплено: ${fmt(g.saved||0)} ₽ (${pct.toFixed(0)}%)</span>
                <span>${done? '' : 'осталось '+fmt(left)+' ₽'}</span>
              </div>
              ${done? '<div class="wish-done-badge">✓ Цель достигнута!</div>' : `
                <div class="wish-add-row">
                  <input type="number" inputmode="decimal" placeholder="отложить сумму" data-goal-input="${g.id}">
                  <button data-goal-add="${g.id}">Отложить</button>
                </div>`}
              ${g.person? `<div style="margin-top:6px"><span class="tag person">${g.person}</span></div>`:''}
            </div>`;
        }).join('');

    body = `
      <div class="tb-section-title">Цели, на&nbsp;которые копим</div>
      <form class="add" id="goalForm">
        <div class="full"><label>Финансовая цель</label><input type="text" id="gName" placeholder="напр., подушка безопасности" required></div>
        <div><label>Цель, ₽</label><input type="number" id="gTarget" step="0.01" min="0" required></div>
        <button type="submit" class="submit">Добавить цель</button>
      </form>
      <div class="list">${goalsListHtml}</div>
      ${goals.length? `<div class="totals" style="margin-top:12px">
        <div class="row2"><span>Всего накоплено</span><span class="pos">${fmt(totalGoalSaved)} ₽</span></div>
        <div class="row2 total"><span>Общая цель</span><span>${fmt(totalGoalTarget)} ₽</span></div>
      </div>` : ''}
    `;
  }

  return monthNav + subtabs + body + ((financeSub==='expenses'||financeSub==='income') ? totalsBox : '');
}

/* ============ РЕНДЕР: СПИСОК ПОКУПОК ============ */
function renderShoppingTab(){
  const me = getDevicePerson();
  const boughtSum = shopping.filter(s=>s.bought && s.price).reduce((sum,s)=>sum+(s.qty||1)*s.price,0);
  const boughtCount = shopping.filter(s=>s.bought).length;

  const grouped = {};
  shopping.forEach(s=>{ (grouped[s.category] = grouped[s.category]||[]).push(s); });

  let listHtml='';
  if(shopping.length===0){
    listHtml = '<div class="empty">Список пуст. Добавьте товары ниже.</div>';
  } else {
    listHtml = Object.entries(grouped).map(([cat,items])=>`
      <div class="date-header">${cat}</div>
      ${items.map(s=>{
        const qty = s.qty||1;
        const lineTotal = qty*(s.price||0);
        const canDelete = s.person===me;
        return `
        <div class="shop-row">
          <div class="shop-item ${s.bought?'bought':'notbought'}" data-toggle="${s.id}">
            <div class="shop-check">${s.bought?'✓':''}</div>
            <div class="shop-main">
              <div class="shop-name-row">
                <span class="shop-name">${s.name}</span>
                <button class="shop-edit no-toggle" data-edit="${s.id}" aria-label="Переименовать">✎</button>
              </div>
              <span class="shop-cat">${s.person||''}</span>
            </div>
            <div class="shop-controls no-toggle">
              <div class="qty-stepper">
                <button data-qty-minus="${s.id}" aria-label="Меньше">–</button>
                <span class="qty-val">${qty}</span>
                <button data-qty-plus="${s.id}" aria-label="Больше">+</button>
              </div>
              <input class="shop-price-input" type="number" inputmode="decimal" placeholder="цена/шт" value="${s.price!=null?s.price:''}" data-price="${s.id}">
              ${qty>1 && s.price? `<span class="shop-line-total">${fmt(lineTotal)} ₽</span>`:''}
            </div>
          </div>
          ${canDelete? `<button class="shop-del-tile" data-del-shop="${s.id}" aria-label="Удалить">×</button>` : ''}
