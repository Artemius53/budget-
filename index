      <span class="donut-dot" style="background:${DONUT_PALETTE[i%DONUT_PALETTE.length]}"></span>
      <span class="donut-legend-label">${label}</span>
      <span class="donut-legend-pct">${(val/total*100).toFixed(0)}%</span>
    </div>`).join('');
  return `
    <div class="donut-wrap">
      <div class="donut" style="background: conic-gradient(${stops});"></div>
      <div class="donut-legend">${legend}</div>
    </div>
  `;
}
function todayStr(){ return new Date().toISOString().slice(0,10); }
function shortDate(iso){ const [y,m,d] = iso.split('-'); return d+'.'+m; }
function tomorrowStr(){ const d=new Date(); d.setDate(d.getDate()+1); return d.toISOString().slice(0,10); }
function dateLabel(iso){
