    <div class="chips">
      ${shopHistory.map(h=>`
        <span class="chip">
          <button type="button" class="chip-add" data-quick-add="${h.name}" data-quick-cat="${h.category}">${h.name}</button>
          <button type="button" class="chip-del" data-del-history="${h.name}" aria-label="Удалить из истории">×</button>
        </span>
      `).join('')}
    </div>
  ` : '';

  return `
    <form class="add" id="shopForm">
      <div class="full"><label>Что купить</label>
        <input type="text" id="sName" list="shopHistoryList" placeholder="напр., молоко" required autocomplete="off">
        <datalist id="shopHistoryList">${shopHistory.map(h=>`<option value="${h.name}">`).join('')}</datalist>
      </div>
      <div><label>Категория</label><select id="sCategory">${SHOP_CATEGORIES.map(c=>`<option>${c}</option>`).join('')}</select></div>
      <div><label>Количество</label>
        <div class="qty-stepper" style="width:100%">
          <button type="button" id="sQtyMinus" aria-label="Меньше">–</button>
          <span class="qty-val" id="sQtyVal">1</span>
          <button type="button" id="sQtyPlus" aria-label="Больше">+</button>
        </div>
        <input type="hidden" id="sQty" value="1">
      </div>
      <button type="submit" class="submit">Добавить в список</button>
    </form>
    ${historyChips}
    ${lastShoppingList.length? `<button class="reset" id="restoreLastList" style="margin-bottom:14px">Добавить прошлый список (${lastShoppingList.length})</button>` : ''}
    <div class="list">${listHtml}</div>
    <div class="totals">
      <div class="row2"><span>Куплено позиций</span><span>${boughtCount} из ${shopping.length}</span></div>
      <div class="row2 total"><span>Потрачено (куплено)</span><span>${fmt(boughtSum)} ₽</span></div>
    </div>
    ${boughtCount>0? '<button class="reset" id="clearBought">Убрать купленные из списка</button>':''}
  `;
}

