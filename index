/* ---- Архивация старых данных (защита от лимита 1 МБ на документ Firestore) ---- */
async function archiveOldData(){
  const cutoff = todayStr().slice(0,7); // YYYY-MM текущего месяца
  const cutoffDate = shiftMonth(cutoff, -12); // всё старше 12 месяцев назад

  const oldExpenses = expenses.filter(e=>monthOf(e.date) < cutoffDate);
  const oldIncomes = incomes.filter(e=>monthOf(e.date) < cutoffDate);

  if(oldExpenses.length===0 && oldIncomes.length===0){
    alert('Нет данных старше 12 месяцев — архивировать нечего.');
    return;
  }
  if(!confirm(`Будет заархивировано: ${oldExpenses.length} расходов и ${oldIncomes.length} доходов (старше ${cutoffDate}). Продолжить?`)) return;

  // Группируем по годам, чтобы каждый архивный документ оставался маленьким
  const byYear = {};
  [...oldExpenses.map(e=>({...e, _kind:'exp'})), ...oldIncomes.map(e=>({...e, _kind:'inc'}))].forEach(r=>{
    const y = r.date.slice(0,4);
    (byYear[y] = byYear[y] || []).push(r);
  });

  try{
    for(const year of Object.keys(byYear)){
      const archiveRef = doc(db, "budget", "archive_"+year);
      const snap = await getDoc(archiveRef).catch(()=>null);
      const existing = (snap && snap.exists()) ? (snap.data().records||[]) : [];
      await setDoc(archiveRef, { records: [...existing, ...byYear[year]] });
    }
    const oldExpIds = new Set(oldExpenses.map(e=>e.id));
    const oldIncIds = new Set(oldIncomes.map(e=>e.id));
    expenses = expenses.filter(e=>!oldExpIds.has(e.id));
    incomes = incomes.filter(e=>!oldIncIds.has(e.id));
    await saveAll();
    alert('Готово. Старые данные перенесены в архив и убраны из основного документа.');
    render();
  }catch(e){
    console.error('Ошибка архивации', e);
    alert('Не удалось заархивировать — проверьте интернет и попробуйте ещё раз.');
  }
}

