function deleteCredit(id){ credits = credits.filter(c=>c.id!==id); saveAll(); render(); }
function creditRemaining(c){
  const paid = expenses.filter(e=>e.creditId===c.id).reduce((s,e)=>s+e.amount,0);
  return Math.max(0, c.totalDebt - paid);
}
function creditPaidThisMonth(c){
  const ym = monthOf(todayStr());
  return expenses.some(e=>e.creditId===c.id && monthOf(e.date)===ym);
}
function payCreditNow(id){
  const c = credits.find(x=>x.id===id);
  if(!c) return;
  addExpense(c.monthlyPayment, 'Кредиты', c.name, todayStr(), '', 'Карта', 'Разовый', getDevicePerson(), null, 'Обязательные', c.id);
}

function getDevicePerson(){
  let p = localStorage.getItem('devicePerson');
  if(!p || !PEOPLE.includes(p)){
    const answer = prompt('Кто вы? Введите: '+PEOPLE.join(' или '));
    if(answer && PEOPLE.includes(answer.trim())){
      p = answer.trim();
      localStorage.setItem('devicePerson', p);
    }
  }
  return (p && PEOPLE.includes(p)) ? p : PEOPLE[0];
}
function changeDevicePerson(){
  localStorage.removeItem('devicePerson');
  const p = getDevicePerson();
  if(window.OneSignalDeferred){
    window.OneSignalDeferred.push(function(OneSignal){ OneSignal.User.addTag('person', p); });
  }
  render();
}
