function renderHistoryTab(){
  let merged = [
    ...expenses.map(e=>({...e, kind:'exp'})),
    ...incomes.map(e=>({...e, kind:'inc'}))
  ].sort((a,b)=> a.date < b.date ? 1 : a.date > b.date ? -1 : 0);

  if(histFilterPerson){
    merged = merged.filter(r=>r.person===histFilterPerson);
  }
  if(histFilterCategory){
    merged = merged.filter(r=>r.category===histFilterCategory);
  }
  if(histFilterText.trim()){
    const q = histFilterText.trim().toLowerCase();
    merged = merged.filter(r=>{
      const inNote = r.note && r.note.toLowerCase().includes(q);
      const inCat = r.category && r.category.toLowerCase().includes(q);
      return inNote || inCat;
    });
  }

  const allCats = [...new Set([...expenses.map(e=>e.category), ...incomes.map(e=>e.category)])];

  const filterHtml = `
    <form class="add" id="histFilterForm" style="margin-bottom:14px">
      <div class="full"><label>Поиск (заметка, категория)</label><input type="text" id="histText" placeholder="напр., отпуск" value="${histFilterText}"></div>
      <div><label>Кто</label><select id="histPerson">
        <option value="">Все</option>
        ${PEOPLE.map(p=>`<option value="${p}" ${histFilterPerson===p?'selected':''}>${p}</option>`).join('')}
      </select></div>
      <div><label>Категория</label><select id="histCategory">
        <option value="">Все</option>
        ${allCats.map(c=>`<option value="${c}" ${histFilterCategory===c?'selected':''}>${c}</option>`).join('')}
      </select></div>
    </form>
  `;

  if(merged.length===0){
    return filterHtml + '<div class="empty">Ничего не найдено.</div>';
  }

  let lastLabel = null;
  const listHtml = merged.map(r=>{
    const label = dateLabel(r.date);
    const headerHtml = label!==lastLabel ? `<div class="date-header">${label}</div>` : '';
    lastLabel = label;
    const isExp = r.kind==='exp';
    return `
      ${headerHtml}
      <div class="row-entry">
        <div class="row">
          <span class="date">${shortDate(r.date)}</span>
          <span class="desc">
            <span class="cat">${r.category}</span>
            ${r.note? `<span class="note">${r.note}</span>`:''}
          </span>
          <span class="leader"></span>
          <span class="amount" style="color:${isExp?'var(--rust)':'var(--forest)'}">${isExp?'−':'+'}${fmt(r.amount)} ₽</span>
          <button class="del" data-hist-del="${r.kind}:${r.id}" aria-label="Удалить">×</button>
        </div>
        <div class="row-meta">
          ${r.person? `<span class="tag person">${r.person}</span>`:''}
          ${isExp && r.expType? `<span class="tag">${r.expType}</span>`:''}
        </div>
      </div>
    `;
  }).join('');

  const totalExpAll = merged.filter(r=>r.kind==='exp').reduce((s,e)=>s+e.amount,0);
  const totalIncAll = merged.filter(r=>r.kind==='inc').reduce((s,e)=>s+e.amount,0);

  return filterHtml + `
    <div class="list">${listHtml}</div>
    <div class="totals">
      <div class="row2"><span>Всего доходов</span><span class="pos">+${fmt(totalIncAll)} ₽</span></div>
      <div class="row2 total"><span>Всего расходов</span><span class="neg">−${fmt(totalExpAll)} ₽</span></div>
    </div>
  `;
}

/* ============ ГЛАВНЫЙ РЕНДЕР ============ */
function renderLimitModal(){
  const ym = todayStr().slice(0,7);
  const monthExp = expenses.filter(e=>monthOf(e.date)===ym);
  const spentByCat = {};
  monthExp.forEach(e=>{ spentByCat[e.category]=(spentByCat[e.category]||0)+e.amount; });
  const limitEntries = Object.entries(categoryLimits);

  return `
    <div class="modal-overlay" id="limitModalOverlay">
      <div class="modal-box">
        <div class="row" style="margin-bottom:12px">
          <div class="tb-title" style="margin:0">Лимиты по категориям</div>
          <button type="button" id="closeLimitModal" style="margin-left:auto;background:none;border:none;font-size:20px;color:var(--ink-soft);cursor:pointer;">×</button>
        </div>
        ${limitEntries.length===0? '<div class="empty" style="padding:6px 0">Лимиты не заданы</div>' : limitEntries.map(([cat,lim])=>{
          const spent = spentByCat[cat]||0;
          const pct = lim>0? Math.min(100,(spent/lim*100)) : 0;
          const over = spent>lim;
          return `
            <div class="bd-row">
              <span class="bd-label">${cat}</span>
              <span class="bd-bar-track"><span class="bd-bar-fill" style="width:${pct.toFixed(0)}%;background:${over?'var(--rust)':'var(--copper)'}"></span></span>
              <span class="bd-amount" style="${over?'color:var(--rust)':''}">${fmt(spent)}/${fmt(lim)} ₽</span>
            </div>`;
        }).join('')}
        <div class="row" style="gap:6px;margin-top:12px">
          <select id="limCategory" style="flex:1;font-size:12px;padding:6px;border:1px solid var(--line);border-radius:6px;">${CATEGORIES.map(c=>`<option>${c}</option>`).join('')}</select>
          <input type="number" id="limAmount" placeholder="лимит, ₽" style="width:90px;font-size:12px;padding:6px;border:1px solid var(--line);border-radius:6px;">
          <button type="button" id="limSaveBtn" class="buy-btn">Задать</button>
        </div>
      </div>
    </div>
  `;
}

function render(){
  const card = document.getElementById('card');
  if(firstLoad){ card.innerHTML = '<div class="loading">Подключение к базе данных…</div>'; return; }

  const totalExpAll = expenses.reduce((s,e)=>s+e.amount,0);
  const totalIncAll = incomes.reduce((s,e)=>s+e.amount,0);
  const balance = totalIncAll - totalExpAll;

  const paceYm = todayStr().slice(0,7);
  const paceExp = expenses.filter(e=>monthOf(e.date)===paceYm).reduce((s,e)=>s+e.amount,0);
  const paceInc = incomes.filter(e=>monthOf(e.date)===paceYm).reduce((s,e)=>s+e.amount,0);
  const paceDaysInMonth = new Date(parseInt(paceYm.slice(0,4)), parseInt(paceYm.slice(5,7)), 0).getDate();
  const paceDayNow = parseInt(todayStr().slice(8,10),10);
  const paceDaysLeft = Math.max(1, paceDaysInMonth - paceDayNow + 1);
  const paceSuggested = Math.max(0, (paceInc - paceExp) / paceDaysLeft);

  let content = '';
  if(activeTab==='home') content = renderHomeTab();
  else if(activeTab==='finance') content = renderFinanceTab();
  else if(activeTab==='shopping') content = renderShoppingTab();
  else if(activeTab==='accounts') content = renderAccountsTab();
  else if(activeTab==='calculator') content = renderCalculatorTab();
  else content = renderHistoryTab();

  card.innerHTML = `
    <button id="enablePush" class="bell-btn" aria-label="Включить уведомления">🔔</button>
    <button id="openHistory" class="bell-btn history-btn" aria-label="История">📜</button>
    <h1>Гроссбух</h1>
    <div class="sub">семейный бюджет</div>
    <div class="sync-status ${connected?'':'offline'}">${connected?'● синхронизировано':'○ нет связи с базой'}</div>
    ${saveError? '<div class="sync-status offline">⚠ Не удалось сохранить — проверьте интернет и повторите</div>' : ''}
    <div class="sync-status">Вы: <b>${getDevicePerson()}</b> · <a href="#" id="changePerson" style="color:var(--copper-text)">сменить</a></div>
    <div class="balance-bar">
      <span>Общий баланс</span>
      <span class="balance-val ${balance<0?'neg':'pos'}">${balance>=0?'+':''}${fmt(balance)} ₽</span>
    </div>
    <div class="limit-bar">
      <button type="button" id="openLimitModal" style="background:none;border:none;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;color:var(--ink-soft);cursor:pointer;padding:0;">Лимит на сегодня ⚙</button>
      <input type="number" id="dailyLimitInput" inputmode="decimal" placeholder="не задан" value="${dailyLimit!=null?dailyLimit:''}">
    </div>
    <div class="sync-status" style="margin-top:-10px">Рекомендуем: ~${fmt(paceSuggested)} ₽/день до конца месяца</div>
    ${showLimitModal? renderLimitModal() : ''}
    <div class="tabs">
      <button class="tab ${activeTab==='home'?'active':''}" id="tabHome">Главная</button>
      <button class="tab ${activeTab==='finance'?'active':''}" id="tabFinance">Финансы</button>
      <button class="tab ${activeTab==='shopping'?'active':''}" id="tabShopping">Покупки</button>
      <button class="tab ${activeTab==='accounts'?'active':''}" id="tabAccounts">Счета</button>
      <button class="tab ${activeTab==='calculator'?'active':''}" id="tabCalculator">Калькулятор</button>
    </div>
    <div style="margin-top:18px">${content}</div>
  `;

  document.getElementById('enablePush').onclick = ()=>{
    const devicePerson = getDevicePerson();
    if(window.OneSignalDeferred){
      window.OneSignalDeferred.push(function(OneSignal){
        OneSignal.User.PushSubscription.optIn();
        setTimeout(()=>{ OneSignal.User.addTag('person', devicePerson); }, 1500);
      });
    }
  };
  document.getElementById('changePerson').onclick = (ev)=>{ ev.preventDefault(); changeDevicePerson(); };
  document.getElementById('openLimitModal').onclick = ()=>{ showLimitModal = true; render(); };
  const closeModalBtn = document.getElementById('closeLimitModal');
  if(closeModalBtn) closeModalBtn.onclick = ()=>{ showLimitModal = false; render(); };
  const overlay = document.getElementById('limitModalOverlay');
  if(overlay) overlay.onclick = (ev)=>{ if(ev.target===overlay){ showLimitModal=false; render(); } };
  const limBtnGlobal = document.getElementById('limSaveBtn');
  if(limBtnGlobal) limBtnGlobal.onclick = ()=>{
    const cat = document.getElementById('limCategory').value;
    const val = parseFloat(document.getElementById('limAmount').value);
    if(!val || val<=0) return;
    setCategoryLimit(cat, val);
  };
  const dlGlobal = document.getElementById('dailyLimitInput');
  dlGlobal.onchange = ()=>{
    const v = parseFloat(dlGlobal.value);
    setDailyLimit(dlGlobal.value===''||isNaN(v) ? null : v);
  };

  document.getElementById('tabHome').onclick = ()=>switchTab('home');
  document.getElementById('tabFinance').onclick = ()=>switchTab('finance');
  document.getElementById('tabShopping').onclick = ()=>switchTab('shopping');
  document.getElementById('tabAccounts').onclick = ()=>switchTab('accounts');
  document.getElementById('tabCalculator').onclick = ()=>switchTab('calculator');
  document.getElementById('openHistory').onclick = (ev)=>{ ev.preventDefault(); switchTab('history'); };

  if(activeTab==='home'){
    // дашборд без интерактивных элементов
  } else if(activeTab==='finance'){
    document.getElementById('prevMonth').onclick = ()=>{ viewMonth = shiftMonth(viewMonth,-1); render(); };
    document.getElementById('nextMonth').onclick = ()=>{ viewMonth = shiftMonth(viewMonth,1); render(); };
    document.getElementById('subExp').onclick = ()=>switchSub('expenses');
    document.getElementById('subInc').onclick = ()=>switchSub('income');
    document.getElementById('subCredits').onclick = ()=>switchSub('credits');
    document.getElementById('subSavings').onclick = ()=>switchSub('savings');
    const tDay = document.getElementById('trendDay');
    const tMonth = document.getElementById('trendMonth');
    const tYear = document.getElementById('trendYear');
    if(tDay) tDay.onclick = ()=>{ trendGranularity='day'; render(); };
    if(tMonth) tMonth.onclick = ()=>{ trendGranularity='month'; render(); };
    if(tYear) tYear.onclick = ()=>{ trendGranularity='year'; render(); };
    card.querySelectorAll('[data-del-credit]').forEach(b=> b.onclick=()=>deleteCredit(b.getAttribute('data-del-credit')));
    card.querySelectorAll('[data-pay-credit]').forEach(b=> b.onclick=()=>payCreditNow(b.getAttribute('data-pay-credit')));

    if(financeSub==='expenses'){
      const f = document.getElementById('addForm');
      f.onsubmit = (ev)=>{
        ev.preventDefault();
        const amount = parseFloat(document.getElementById('amount').value);
        if(!amount || amount<=0) return;
        addExpense(amount,
          document.getElementById('category').value,
          document.getElementById('note').value.trim(),
          document.getElementById('date').value || todayStr(),
          document.getElementById('place').value.trim(),
          'Карта',
          document.getElementById('recurring').value,
          getDevicePerson(),
          document.getElementById('expAccount').value || null,
          document.getElementById('expType').value,
          (document.getElementById('expCredit')? document.getElementById('expCredit').value : '') || null);
      };
      card.querySelectorAll('[data-del-exp]').forEach(b=> b.onclick=()=>deleteExpense(b.getAttribute('data-del-exp')));
    } else if(financeSub==='income'){
      const f = document.getElementById('incomeForm');
      f.onsubmit = (ev)=>{
        ev.preventDefault();
        const amount = parseFloat(document.getElementById('iAmount').value);
        if(!amount || amount<=0) return;
        addIncome(amount,
          document.getElementById('iCategory').value,
          document.getElementById('iNote').value.trim(),
          document.getElementById('iDate').value || todayStr(),
          getDevicePerson(),
          document.getElementById('incAccount').value || null);
      };
      card.querySelectorAll('[data-del-inc]').forEach(b=> b.onclick=()=>deleteIncome(b.getAttribute('data-del-inc')));
    } else if(financeSub==='credits'){
      const crForm = document.getElementById('creditForm');
      crForm.onsubmit = (ev)=>{
        ev.preventDefault();
        const name = document.getElementById('crName').value.trim();
        const total = parseFloat(document.getElementById('crTotal').value);
        const rate = parseFloat(document.getElementById('crRate').value);
        const payment = parseFloat(document.getElementById('crPayment').value);
        const day = parseInt(document.getElementById('crDay').value,10) || 1;
        if(!name || isNaN(total) || isNaN(payment)) return;
        addCredit(document.getElementById('crPerson').value, name, document.getElementById('crType').value, total, isNaN(rate)?null:rate, payment, day);
      };
    } else if(financeSub==='savings'){
      document.getElementById('goalForm').onsubmit = (ev)=>{
        ev.preventDefault();
        const name = document.getElementById('gName').value.trim();
        const target = parseFloat(document.getElementById('gTarget').value);
        if(!name || !target || target<=0) return;
        addGoal(name, target, getDevicePerson());
      };
      card.querySelectorAll('[data-del-goal]').forEach(b=> b.onclick=()=>deleteGoal(b.getAttribute('data-del-goal')));
      card.querySelectorAll('[data-edit-goal]').forEach(b=> b.onclick=()=>editGoal(b.getAttribute('data-edit-goal')));
      card.querySelectorAll('[data-goal-add]').forEach(b=>{
        b.onclick = ()=>{
          const id = b.getAttribute('data-goal-add');
          const inp = card.querySelector(`[data-goal-input="${id}"]`);
          const v = parseFloat(inp.value);
          if(!v || v<=0) return;
          addToGoal(id, v);
        };
      });
    }
  } else if(activeTab==='shopping'){
    document.getElementById('shopForm').onsubmit = (ev)=>{
      ev.preventDefault();
      const name = document.getElementById('sName').value.trim();
      if(!name) return;
      const qty = parseInt(document.getElementById('sQty').value,10) || 1;
      addShopItem(name, document.getElementById('sCategory').value, getDevicePerson(), qty);
      document.getElementById('sQty').value = '1';
    };
    const qtyValEl = document.getElementById('sQtyVal');
    const qtyInputEl = document.getElementById('sQty');
    document.getElementById('sQtyMinus').onclick = ()=>{
      const v = Math.max(1, parseInt(qtyInputEl.value,10)-1);
      qtyInputEl.value = v; qtyValEl.textContent = v;
    };
    document.getElementById('sQtyPlus').onclick = ()=>{
      const v = parseInt(qtyInputEl.value,10)+1;
      qtyInputEl.value = v; qtyValEl.textContent = v;
    };
    card.querySelectorAll('[data-quick-add]').forEach(b=>{
      b.onclick = ()=> addShopItem(b.getAttribute('data-quick-add'), b.getAttribute('data-quick-cat'), getDevicePerson(), 1);
    });
    card.querySelectorAll('[data-del-history]').forEach(b=>{
      b.onclick = ()=> deleteShopHistoryItem(b.getAttribute('data-del-history'));
    });
    card.querySelectorAll('.shop-item').forEach(el=>{
      el.addEventListener('click', (ev)=>{
        if(ev.target.closest('.no-toggle')) return;
        toggleBought(el.getAttribute('data-toggle'));
      });
    });
    card.querySelectorAll('[data-del-shop]').forEach(b=> b.onclick=()=>deleteShopItem(b.getAttribute('data-del-shop')));
    card.querySelectorAll('[data-edit]').forEach(b=> b.onclick=()=>renameShopItem(b.getAttribute('data-edit')));
    card.querySelectorAll('[data-qty-minus]').forEach(b=> b.onclick=()=>changeShopQty(b.getAttribute('data-qty-minus'), -1));
    card.querySelectorAll('[data-qty-plus]').forEach(b=> b.onclick=()=>changeShopQty(b.getAttribute('data-qty-plus'), 1));
    card.querySelectorAll('[data-price]').forEach(inp=>{
      inp.onchange = ()=>{
        const v = parseFloat(inp.value);
        setShopPrice(inp.getAttribute('data-price'), isNaN(v)? null : v);
      };
    });
    const cb = document.getElementById('clearBought');
    if(cb) cb.onclick = clearBoughtShop;
    const rl = document.getElementById('restoreLastList');
    if(rl) rl.onclick = restoreLastShoppingList;
  } else if(activeTab==='accounts'){
    card.querySelectorAll('[data-del-account]').forEach(b=> b.onclick=()=>deleteAccount(b.getAttribute('data-del-account')));
    document.getElementById('accountForm').onsubmit = (ev)=>{
      ev.preventDefault();
      const owner = document.getElementById('accOwner').value;
      const bank = document.getElementById('accBank').value.trim();
      const balance = parseFloat(document.getElementById('accBalance').value);
      if(!bank || isNaN(balance)) return;
      addAccount(owner, bank, balance);
    };
    document.getElementById('archiveBtn').onclick = archiveOldData;
  } else if(activeTab==='calculator'){
    document.getElementById('calcSubBasic').onclick = ()=>{ calculatorSub='basic'; render(); };
    document.getElementById('calcSubWeight').onclick = ()=>{ calculatorSub='weight'; render(); };

    if(calculatorSub==='basic'){
      card.querySelectorAll('[data-calc-digit]').forEach(b=> b.onclick=()=>calcInputDigit(b.getAttribute('data-calc-digit')));
      card.querySelectorAll('[data-calc-op]').forEach(b=> b.onclick=()=>calcSetOperator(b.getAttribute('data-calc-op')));
      const dotBtn = document.querySelector('[data-calc-dot]');
      if(dotBtn) dotBtn.onclick = calcInputDot;
      const clearBtn = document.querySelector('[data-calc-clear]');
      if(clearBtn) clearBtn.onclick = calcClear;
      const backBtn = document.querySelector('[data-calc-back]');
      if(backBtn) backBtn.onclick = calcBackspace;
      const eqBtn = document.querySelector('[data-calc-equals]');
      if(eqBtn) eqBtn.onclick = calcEquals;
    } else {
      const measureSel = document.getElementById('wcMeasure');
      measureSel.onchange = ()=>{ unitMeasure = measureSel.value; render(); };
      const priceInp = document.getElementById('wcPrice');
      const gramsInp = document.getElementById('wcGrams');
      const updateWeightResult = ()=>{
        unitPrice = priceInp.value;
        unitQty = gramsInp.value;
        const m = MEASURES[unitMeasure];
        const price = parseFloat(unitPrice)||0;
        const qty = parseFloat(unitQty)||0;
        const result = (price/m.factor)*qty;
        document.getElementById('wcResult').textContent = fmt(result) + ' ₽';
        document.getElementById('wcGramsLabel').textContent = (qty? fmt(qty):'0') + ' ' + m.qtyUnit + ' будут стоить';
      };
      priceInp.oninput = updateWeightResult;
      gramsInp.oninput = updateWeightResult;
    }
  } else {
    card.querySelectorAll('[data-hist-del]').forEach(b=>{
      b.onclick = ()=>{
        const [kind, id] = b.getAttribute('data-hist-del').split(':');
        if(kind==='exp') deleteExpense(id); else deleteIncome(id);
      };
    });
    const hText = document.getElementById('histText');
    const hPerson = document.getElementById('histPerson');
    const hCategory = document.getElementById('histCategory');
    const hForm = document.getElementById('histFilterForm');
    if(hForm) hForm.onsubmit = (ev)=> ev.preventDefault();
    if(hText) hText.onchange = ()=>{ histFilterText = hText.value; render(); };
    if(hPerson) hPerson.onchange = ()=>{ histFilterPerson = hPerson.value; render(); };
    if(hCategory) hCategory.onchange = ()=>{ histFilterCategory = hCategory.value; render(); };
  }
}
</script>
</body>
</html>
