    } else {
      const eid = newId();
      item.expenseId = eid;
      expenses.push({ id:eid, amount:lineTotal, category:item.category||'Другое', note:item.name+(item.qty>1?` ×${item.qty}`:''), date:todayStr(), place:'', paymentMethod:'Карта', recurring:'Разовый', person:item.person });
      expenses.sort((a,b)=> a.date < b.date ? 1 : -1);
    }
  }
  if((!item.bought || !item.price) && item.expenseId){
    expenses = expenses.filter(e=>e.id!==item.expenseId);
    item.expenseId = null;
  }
}
