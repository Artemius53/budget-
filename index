<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Гроссбух">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<meta name="theme-color" content="#DEE3D6">
<title>Гроссбух</title>
<link rel="manifest" href="manifest.json">
<script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
<script>
  window.OneSignalDeferred = window.OneSignalDeferred || [];
  OneSignalDeferred.push(async function(OneSignal) {
    await OneSignal.init({
      appId: "88ee6a98-6240-4163-affd-f898481352d6",
      safari_web_id: "web.onesignal.auto.1a94b592-c98a-427e-9490-520bfcd23754",
      serviceWorkerPath: "budget-/OneSignalSDKWorker.js",
      serviceWorkerParam: { scope: "/budget-/" },
    });
  });
