<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #DEE3D6;
    --paper: #EEF1E9;
    --line: #C9CFC0;
    --ink: #1C2B22;
    --ink-soft: #5B6B5F;
    --copper: #A6672C;
    --copper-text: #955C27;
    --forest: #2F5233;
    --rust: #A63A2E;
  }
  *{box-sizing:border-box;}
  html{ -webkit-text-size-adjust: 100%; }
  body{
    margin:0;
    min-height:100vh;
    background: var(--bg);
    background-image: radial-gradient(circle at 1px 1px, rgba(28,43,34,0.06) 1px, transparent 0);
    background-size: 18px 18px;
    display:flex;
    justify-content:center;
    padding: max(24px, env(safe-area-inset-top)) 16px calc(40px + env(safe-area-inset-bottom));
    font-family: 'Bitter', Georgia, serif;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
  }
  .card{
    position:relative;
    width:100%;
    max-width:440px;
    background: var(--paper);
    box-shadow: 0 24px 48px rgba(28,43,34,0.16);
    padding: 34px 26px calc(78px + env(safe-area-inset-bottom, 0px));
  }
  .bell-btn{
    position:absolute;
    top:12px;
    right:14px;
    width:40px; height:40px;
    border-radius:50%;
    border:1px solid var(--line);
    background:#fff;
    font-size:16px;
    line-height:1;
    cursor:pointer;
    z-index:5;
    -webkit-tap-highlight-color: transparent;
  }
  .bell-btn:active{ background: rgba(28,43,34,0.06); }
  .history-btn{ right:56px; }
  .card::before, .card::after{
    content:'';
    position:absolute;
    left:0; right:0;
    height:14px;
    background: radial-gradient(circle at 10px 7px, var(--bg) 6px, transparent 6.5px);
    background-size: 20px 14px;
  }
  .card::before{ top:-1px; }
  .card::after{ bottom:-1px; }

  h1{
    font-family:'Bitter', Georgia, serif;
    font-weight:700;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-size: 24px;
    text-align:center;
    margin: 4px 0 2px;
  }
  .sub{
    text-align:center;
    font-size:12px;
    color: var(--ink-soft);
    letter-spacing: 1px;
    margin-bottom: 14px;
  }
  .sync-status{
    text-align:center;
    font-size:10px;
    color: var(--forest);
    letter-spacing: 0.5px;
    margin-bottom: 14px;
  }
  .sync-status.offline{ color: var(--rust); }

  .balance-bar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: 10px 14px;
    background: rgba(28,43,34,0.05);
    border-radius:8px;
    margin-bottom: 14px;
    font-size:13px;
    color: var(--ink-soft);
    text-transform:uppercase;
    letter-spacing:1px;
  }
  .balance-bar .balance-val{
    font-family:'IBM Plex Mono', monospace;
    font-size:17px;
    font-weight:600;
    letter-spacing:0;
  }
  .balance-bar .balance-val.pos{ color: var(--forest); }
  .balance-bar .balance-val.neg{ color: var(--rust); }
  .limit-bar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: 8px 14px;
    background: rgba(166,103,44,0.08);
    border-radius:8px;
    margin-bottom: 14px;
    font-size:12px;
    color: var(--ink-soft);
    text-transform:uppercase;
    letter-spacing:0.5px;
  }
  .limit-bar input{
    width:100px;
    text-align:right;
    font-family:'IBM Plex Mono', monospace;
    font-size:15px;
    border:none;
    background:transparent;
    color: var(--copper-text);
    font-weight:600;
  }

  .tabs{
    display:flex;
    gap:4px;
    border-top: 2px solid var(--ink);
    position: fixed;
    left:50%;
    transform: translateX(-50%);
    bottom:0;
    width:100%;
    max-width:440px;
    background: var(--paper);
    z-index: 50;
    padding: 0 8px calc(6px + env(safe-area-inset-bottom, 0px));
    box-shadow: 0 -4px 10px -4px rgba(28,43,34,0.12);
  }
  .tab{
    flex:1;
    text-align:center;
    padding: 12px 2px;
    min-height:48px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Bitter', Georgia, serif;
    font-weight:700;
    font-size:9.5px;
    letter-spacing:0.3px;
    text-transform:uppercase;
    color: var(--ink-soft);
    background: rgba(28,43,34,0.03);
    border:none;
    border-radius:0 0 6px 6px;
    cursor:pointer;
    position:relative;
    white-space:nowrap;
    -webkit-tap-highlight-color: transparent;
  }
  .tab.active{
    color: var(--ink);
    background: rgba(166,103,44,0.1);
    border-top: 2px solid var(--copper);
    margin-top:-2px;
  }

  .home-greeting{
    font-family:'Bitter', Georgia, serif;
    font-weight:700;
    font-size:18px;
    text-align:center;
    margin-bottom:16px;
  }

  .month-nav{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    margin-bottom: 16px;
  }
  .calc-display{
    font-family:'IBM Plex Mono', monospace;
    font-size:36px;
    font-weight:600;
    text-align:right;
    padding:16px 12px;
    background: rgba(28,43,34,0.04);
    border-radius:8px;
    margin-bottom:14px;
    overflow-x:auto;
    white-space:nowrap;
  }
  .calc-grid{
    display:grid;
    grid-template-columns: repeat(4, 1fr);
    gap:8px;
  }
  .calc-btn{
    min-height:56px;
    border:none;
    border-radius:8px;
    background:#fff;
    border:1px solid var(--line);
    font-family:'IBM Plex Mono', monospace;
    font-size:20px;
    color: var(--ink);
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .calc-btn:active{ background: rgba(28,43,34,0.08); }
  .calc-btn.calc-op{ background: rgba(166,103,44,0.1); color: var(--copper-text); font-weight:700; }
  .calc-btn.calc-fn{ background: rgba(166,58,46,0.08); color: var(--rust); font-weight:700; }
  .calc-btn.calc-eq{ background: var(--ink); color: var(--paper); font-weight:700; }

  .month-nav button{
    background: rgba(28,43,34,0.06);
    border:none;
    width:36px; height:36px;
    border-radius:50%;
    font-size:16px;
    color: var(--ink);
    cursor:pointer;
    flex-shrink:0;
    -webkit-tap-highlight-color: transparent;
  }
  .month-nav button:active{ background: rgba(28,43,34,0.14); }
  .month-nav .month-label{
    font-family:'Bitter', Georgia, serif;
    font-weight:700;
    font-size:13px;
    text-transform:uppercase;
    letter-spacing:0.5px;
    text-align:center;
    white-space:nowrap;
  }

  .subtabs{
    display:flex;
    gap:6px;
    margin-bottom:16px;
  }
  .subtab{
    flex:1;
    text-align:center;
    padding:7px 2px;
    font-size:10.5px;
    font-weight:600;
    border-radius:6px;
    border:1px solid var(--line);
    background:#fff;
    color: var(--ink-soft);
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .subtab.active{ background: var(--ink); color: var(--paper); border-color: var(--ink); }

  .budget-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    font-size:13px;
    color: var(--ink-soft);
    margin-bottom: 18px;
  }
  .budget-row input{
    width:110px;
    text-align:right;
    font-family:'IBM Plex Mono', monospace;
    font-size:16px;
    border:none;
    border-bottom:1px dashed var(--line);
    background:transparent;
    color: var(--ink);
    padding:2px 2px 4px;
  }
  .budget-row input:focus-visible{ outline: 2px solid var(--copper); outline-offset:2px; }

  form.add{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:10px;
    padding: 16px 0 18px;
    border-top: 1px dashed var(--line);
    border-bottom: 1px dashed var(--line);
    margin-bottom: 18px;
  }
  form.add .full{ grid-column: 1 / -1; }
  form.add label{
    display:block;
    font-size:10px;
    text-transform:uppercase;
    letter-spacing:1px;
    color: var(--ink-soft);
    margin-bottom:4px;
  }
  form.add input, form.add select{
    width:100%;
    font-family:'Bitter', Georgia, serif;
    font-size:16px;
    padding:10px 10px;
    border:1px solid var(--line);
    background:#fff;
    color: var(--ink);
    border-radius:6px;
  }
  form.add input[type="number"]{ font-family:'IBM Plex Mono', monospace; }
  form.add input[type="date"]{
    -webkit-appearance: none;
    appearance: none;
    height: 44px;
    line-height: 1.2;
    text-align: left;
    min-width: 0;
  }
  form.add input:focus-visible, form.add select:focus-visible{
    outline:2px solid var(--copper); outline-offset:1px;
  }
  button.submit{
    grid-column: 1 / -1;
    margin-top:4px;
    background: var(--ink);
    color: var(--paper);
    border:none;
    padding:14px;
    font-family:'Bitter', Georgia, serif;
    font-weight:700;
    letter-spacing:1px;
    text-transform:uppercase;
    font-size:14px;
    cursor:pointer;
    border-radius:6px;
    -webkit-tap-highlight-color: transparent;
  }
  button.submit:hover{ background: var(--forest); }
  button.submit:focus-visible{ outline:2px solid var(--copper); outline-offset:2px; }

  .list{ min-height: 40px; }
  .row{
    display:flex;
    align-items:baseline;
    gap:6px;
    padding: 9px 0;
    font-size:13px;
  }
  .row .date{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    color: var(--ink-soft);
    width:42px;
    flex-shrink:0;
  }
  .row .desc{
    display:flex;
    flex-direction:column;
    flex-shrink:0;
    max-width:40%;
  }
  .row .cat{ font-weight:600; }
  .row .place{ font-size:11px; color: var(--ink-soft); }
  .row .note{ font-size:11px; color: var(--ink-soft); font-style:italic; }
  .row .leader{
    flex:1;
    border-bottom: 1px dotted var(--line);
    margin: 0 4px 4px;
  }
  .row .amount{
    font-family:'IBM Plex Mono', monospace;
    font-weight:600;
    flex-shrink:0;
    white-space:nowrap;
  }
  .row .del{
    background:none;
    border:none;
    color: var(--ink-soft);
    cursor:pointer;
    font-size:20px;
    line-height:1;
    padding:10px 6px 10px 12px;
    margin:-10px -6px -10px 0;
    flex-shrink:0;
    -webkit-tap-highlight-color: transparent;
  }
  .row .del:hover, .row .del:active{ color: var(--rust); }
  .row-entry{ padding: 9px 0; }
  .row-entry + .row-entry{ border-top: 1px solid rgba(28,43,34,0.05); }
  .date-header{
    font-family:'Bitter', Georgia, serif;
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:1px;
    color: var(--copper-text);
    margin-top:14px;
    padding-bottom:4px;
    border-bottom:1px solid var(--line);
  }
  .date-header:first-child{ margin-top:0; }
  .row-meta{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    gap:6px;
    margin-top:3px;
    padding-left:48px;
  }
  .tag{
    font-size:10px;
    text-transform:uppercase;
    letter-spacing:0.5px;
    color: var(--ink-soft);
    background: rgba(28,43,34,0.06);
    border-radius:3px;
    padding:2px 6px;
  }
  .tag.recurring{ color: var(--copper-text); background: rgba(166,103,44,0.12); }
  .tag.person{ color: var(--forest); background: rgba(47,82,51,0.12); font-weight:600; }
  .tag.priority-high{ color: var(--rust); background: rgba(166,58,46,0.12); }
  .tag.priority-mid{ color: var(--copper-text); background: rgba(166,103,44,0.12); }
  .tag.priority-low{ color: var(--ink-soft); }

  .buy-btn{
    margin-left:auto;
    font-family:'Bitter', Georgia, serif;
    font-size:11px;
    color: var(--forest);
    background: rgba(47,82,51,0.1);
    border:1px solid rgba(47,82,51,0.3);
    border-radius:3px;
    padding:6px 10px;
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .buy-btn:hover{ background: var(--forest); color: var(--paper); }

  .breakdown{
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed var(--line);
  }
  .breakdown-title{
    font-size:10px;
    text-transform:uppercase;
    letter-spacing:1px;
    color: var(--ink-soft);
    margin-bottom:8px;
  }
  .bd-row{
    display:flex;
    align-items:center;
    gap:8px;
    font-size:12px;
    margin-bottom:6px;
  }
  .bd-row .bd-label{ width:84px; flex-shrink:0; }
  .bd-row.top .bd-label{ color: var(--rust); font-weight:600; }
  .bd-row .bd-bar-track{
    flex:1;
    height:6px;
    background: rgba(28,43,34,0.08);
    border-radius:3px;
    overflow:hidden;
  }
  .bd-row .bd-bar-fill{
    height:100%;
    background: var(--copper);
    border-radius:3px;
  }
  .bd-row.top .bd-bar-fill{ background: var(--rust); }
  .bd-row .bd-amount{
    font-family:'IBM Plex Mono', monospace;
    min-width:64px;
    text-align:right;
    flex-shrink:0;
    white-space:nowrap;
  }
  .bd-row.top .bd-amount{ color: var(--rust); font-weight:600; }

  .totals-box{
    margin-top:16px;
    padding:14px;
    border:2px solid var(--ink);
    border-radius:8px;
  }
  .totals-box .tb-title{
    font-family:'Bitter', Georgia, serif;
    font-weight:700;
    font-size:13px;
    letter-spacing:2px;
    text-transform:uppercase;
    text-align:center;
    margin-bottom:12px;
  }
  .tb-section-title{
    font-size:10px;
    text-transform:uppercase;
    letter-spacing:1px;
    color: var(--ink-soft);
    margin:10px 0 6px;
  }
  .trend-row{
    display:flex;
    align-items:center;
    gap:8px;
    margin-bottom:5px;
  }
  .trend-month{
    width:38px;
    flex-shrink:0;
    font-size:11px;
    text-transform:uppercase;
    color: var(--ink-soft);
  }
  .trend-bars{ flex:1; display:flex; flex-direction:column; gap:2px; }
  .trend-bar-track{
    height:6px;
    background: rgba(28,43,34,0.07);
    border-radius:3px;
    overflow:hidden;
  }
  .trend-bar{ height:100%; border-radius:3px; }
  .trend-bar.income{ background: var(--forest); }
  .trend-bar.expense{ background: var(--rust); }
  .empty{
    text-align:center;
    color: var(--ink-soft);
    font-size:13px;
    padding: 24px 0;
  }
  .donut-wrap{ display:flex; align-items:center; gap:14px; margin:10px 0; }
  .donut{
    width:96px; height:96px; border-radius:50%; flex-shrink:0;
    position:relative;
  }
  .donut::after{
    content:''; position:absolute; inset:22px;
    background: var(--paper); border-radius:50%;
  }
  .donut-legend{ flex:1; display:flex; flex-direction:column; gap:4px; }
  .donut-legend-row{ display:flex; align-items:center; gap:6px; font-size:11px; }
  .donut-dot{ width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .donut-legend-label{ flex:1; color: var(--ink-soft); }
  .donut-legend-pct{ font-family:'IBM Plex Mono',monospace; font-weight:600; }

  .totals{
    margin-top: 12px;
    padding-top: 14px;
    border-top: 2px solid var(--ink);
  }
  .totals .row2{
    display:flex;
    justify-content:space-between;
    align-items:baseline;
    gap:12px;
    font-family:'IBM Plex Mono', monospace;
    font-size:14px;
    margin-bottom:4px;
  }
  .totals .row2 span:first-child{ flex:1; min-width:0; }
  .totals .row2 span:last-child{ white-space:nowrap; flex-shrink:0; }
  .totals .row2.total{ font-weight:600; font-size:16px; }
  .totals .row2 .neg{ color: var(--rust); }
  .totals .row2 .pos{ color: var(--forest); }

  /* Список покупок */
  .shop-row{
    display:flex;
    align-items:stretch;
    gap:8px;
    margin-bottom:7px;
  }
  .shop-item{
    display:flex;
    align-items:flex-start;
    flex-wrap:wrap;
    gap:8px 10px;
    padding:11px 10px;
    border-radius:6px;
    flex:1;
    min-width:0;
    border:1px solid var(--line);
    background:#fff;
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .shop-item:active{ opacity:0.85; }
  .shop-item.bought{ background: rgba(47,82,51,0.12); border-color: rgba(47,82,51,0.4); }
  .shop-item.notbought{ background: rgba(166,58,46,0.09); border-color: rgba(166,58,46,0.35); }
  .shop-del-tile{
    flex-shrink:0;
    width:44px;
    min-height:44px;
    border-radius:6px;
    border:1px solid var(--line);
    background:#fff;
    color: var(--ink-soft);
    font-size:18px;
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .shop-del-tile:active{ color: var(--rust); border-color: var(--rust); }
  .chips{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-bottom:14px;
  }
  .chip{
    display:inline-flex;
    align-items:center;
    gap:4px;
    font-size:11px;
    padding:2px 2px 2px 10px;
    border-radius:14px;
    border:1px solid var(--line);
    background:#fff;
    color: var(--ink-soft);
  }
  .chip-add{
    background:none;
    border:none;
    font-size:11px;
    color: var(--ink-soft);
    cursor:pointer;
    padding:3px 0;
    -webkit-tap-highlight-color: transparent;
  }
  .chip-add:active{ color: var(--ink); }
  .chip-del{
    background: rgba(28,43,34,0.06);
    border:none;
    border-radius:50%;
    width:26px; height:26px;
    font-size:13px;
    line-height:1;
    color: var(--ink-soft);
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .chip-del:active{ color: var(--rust); background: rgba(166,58,46,0.12); }
  .modal-overlay{
    position:fixed; inset:0;
    background: rgba(28,43,34,0.5);
    display:flex; align-items:center; justify-content:center;
    z-index:100;
    padding:20px;
  }
  .modal-box{
    background: var(--paper);
    border-radius:10px;
    padding:20px;
    max-width:380px;
    width:100%;
    max-height:80vh;
    overflow-y:auto;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .shop-check{
    width:32px; height:32px;
    margin-top:1px;
    border-radius:50%;
    border:2px solid var(--ink-soft);
    flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
    font-size:15px; color:#fff;
  }
  .shop-item.bought .shop-check{ background: var(--forest); border-color: var(--forest); }
  .shop-main{ flex:1; min-width:120px; }
  .shop-name-row{ display:flex; align-items:center; gap:6px; }
  .shop-item .shop-name{ font-size:15px; }
  .shop-item.bought .shop-name{ text-decoration: line-through; color: var(--ink-soft); }
  .shop-edit{
    background:none; border:none; color: var(--ink-soft);
    cursor:pointer; font-size:13px; padding:2px 4px;
    -webkit-tap-highlight-color: transparent;
  }
  .shop-edit:active{ color: var(--copper-text); }
  .shop-item .shop-cat{ font-size:10px; text-transform:uppercase; letter-spacing:0.5px; color: var(--ink-soft); display:block; }
  .shop-controls{
    display:flex;
