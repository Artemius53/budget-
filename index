function buildDonut(entries){
  const total = entries.reduce((s,e)=>s+e[1],0);
  if(total<=0) return '';
  let acc = 0;
  const stops = entries.map(([label,val],i)=>{
    const start = (acc/total*100).toFixed(1);
    acc += val;
    const end = (acc/total*100).toFixed(1);
    return `${DONUT_PALETTE[i%DONUT_PALETTE.length]} ${start}% ${end}%`;
  }).join(', ');
